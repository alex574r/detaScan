# DentaScan — Variables de entorno
# Copia este archivo como .env y ajusta los valores

# ── Aplicación ──────────────────────────────────────────────────────────────
APP_NAME=DentaScan
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ── Servidor ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:5500"]

# ── Seguridad — CAMBIA ESTO EN PRODUCCIÓN ───────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_en_produccion_ahora_mismo_secreto_muy_largo
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Base de datos ────────────────────────────────────────────────────────────
# SQLite (default, sin configuración extra):
DATABASE_URL=sqlite:///./dentascan.db

# PostgreSQL (producción):
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/dentascan

# ── Archivos ─────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Procesamiento ────────────────────────────────────────────────────────────
CLAHE_CLIP_LIMIT=2.0
GAUSSIAN_KERNEL_SIZE=5
MEDIAN_KERNEL_SIZE=3
CANNY_LOW_THRESHOLD=50
CANNY_HIGH_THRESHOLD=150

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/dentascan.log
